  "license": "MIT",
  "homepage": "https://github.com/CherryAI/anti-hallucination",
  "repository": "https://github.com/CherryAI/anti-hallucination",
  "engines": {
    "openclaw": ">=2026.5.0"
  },
  "dependencies": [],
  "keywords": ["anti-hallucination", "fact-checking", "accuracy", "verification", "safety"],
  "structure": {
    "rules": ["pre-check.md", "in-process.md", "post-check.md"],
    "hooks": ["fact-check.md", "code-verify.md"],
    "scripts": ["validate_output.py", "tool_hook.py"],
    "assets": ["prompt_template.md"]
  },
  "modes": ["strict", "balanced", "fast"]
